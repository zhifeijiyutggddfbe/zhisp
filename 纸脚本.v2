   Name = "开启自动拳击 (Kill Aura)",
   CurrentValue = false,
   Callback = function(Value)
      AuraEnabled = Value
      if Value then
         task.spawn(function()
            while AuraEnabled do
               local meleeEvent = ReplicatedStorage:FindFirstChild("meleeEvent")
               if meleeEvent and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                  for _, p in ipairs(Players:GetPlayers()) do
                     if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                        local distance = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                        if distance <= AuraRange then
                           meleeEvent:FireServer(p, 1, 1)
                        end
                     end
                  end
               end
               task.wait(0.1)
            end
         end)
      end
   end,
})

