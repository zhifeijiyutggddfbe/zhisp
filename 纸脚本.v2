-- [[ 监狱人生 完整整合脚本 - 100% 原始功能修复版 ]]

local PrisonTab = Window:CreateTab("监狱人生", 4483362458)

-- 变量初始化 (完全保留你的 settings 命名)
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local settings = {
    antiarrest = false,
    antitase = false,
    autoArrest = false
}

-- ==========================================
-- 核心逻辑：监听动画 (修正了闭合错误)
-- ==========================================
local lastPos = nil 

local function ConnectCharacter(char)
    local humanoid = char:WaitForChild("Humanoid")
    local root = char:WaitForChild("HumanoidRootPart")
    local animator = humanoid:WaitForChild("Animator")

    animator.AnimationPlayed:Connect(function(des)
        -- 反逮捕
        if settings.antiarrest and des.Animation.AnimationId == "rbxassetid://287112271" then
            lastPos = root.CFrame
            humanoid.Health = 0
            Rayfield:Notify({
                Title = "反逮捕成功",
                Content = "已执行自杀并记录坐标，正在尝试回传...",
                Duration = 3
            })
        end

        -- 反电击 (修复了之前逻辑断裂的地方)
        if settings.antitase and des.Animation.AnimationId == "rbxassetid://279227693" then
            des:Stop()
            humanoid.PlatformStand = false
            task.wait()
            humanoid.WalkSpeed = 16
        end
    end)
end

-- 监听复活并执行回传
LocalPlayer.CharacterAdded:Connect(function(newChar)
    if lastPos then
        local newRoot = newChar:WaitForChild("HumanoidRootPart")
        task.wait(0.5) 
        newRoot.CFrame = lastPos
        lastPos = nil 
    end
    ConnectCharacter(newChar)
end)

-- 初始启动
if LocalPlayer.Character then
    ConnectCharacter(LocalPlayer.Character)
end

