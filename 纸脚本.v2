                                LocalPlayer.Character.HumanoidRootPart.CFrame = v.Character.HumanoidRootPart.CFrame
                                ReplicatedStorage.Remotes.ArrestPlayer:InvokeServer(v)
                            end
                        end
                    end
                    task.wait(0.5)
                end
            end)
        end
    end
})

